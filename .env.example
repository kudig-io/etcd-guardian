# EtcdGuardian Environment Configuration
# Copy this file to .env and update values as needed

# =============================================================================
# General Configuration
# =============================================================================
APP_NAME=etcd-guardian
ENVIRONMENT=production
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# Operator Configuration
# =============================================================================
OPERATOR_NAMESPACE=etcd-guardian-system
OPERATOR_IMAGE=etcdguardian/operator:latest
OPERATOR_REPLICAS=1

# Leader Election
LEADER_ELECTION_ENABLED=true
LEADER_ELECTION_ID=etcdguardian.io
LEADER_ELECTION_LEASE_DURATION=15s
LEADER_ELECTION_RENEW_DEADLINE=10s
LEADER_ELECTION_RETRY_PERIOD=2s

# Metrics
METRICS_BIND_ADDRESS=:8080
HEALTH_PROBE_BIND_ADDRESS=:8081

# =============================================================================
# Backend API Configuration
# =============================================================================
BACKEND_IMAGE=etcdguardian/backend:latest
BACKEND_PORT=8080
BACKEND_REPLICAS=2

# Gin Configuration
GIN_MODE=release

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://etcdguardian.io,https://app.etcdguardian.io
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization
CORS_MAX_AGE=86400

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=1m

# =============================================================================
# Web UI Configuration
# =============================================================================
WEBUI_IMAGE=etcdguardian/web-ui:latest
WEBUI_PORT=80
WEBUI_REPLICAS=2

# API Endpoint
REACT_APP_API_URL=https://api.etcdguardian.io

# =============================================================================
# etcd Configuration
# =============================================================================
ETCD_ENDPOINTS=https://etcd-0:2379,https://etcd-1:2379,https://etcd-2:2379
ETCD_CA_CERT=/etc/etcd/pki/ca.crt
ETCD_CLIENT_CERT=/etc/etcd/pki/client.crt
ETCD_CLIENT_KEY=/etc/etcd/pki/client.key
ETCD_DIAL_TIMEOUT=5s
ETCD_REQUEST_TIMEOUT=30s

# =============================================================================
# Storage Configuration - S3
# =============================================================================
STORAGE_PROVIDER=S3
S3_BUCKET=my-etcd-backups
S3_REGION=us-east-1
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# Storage Configuration - OSS (Alibaba Cloud)
# STORAGE_PROVIDER=OSS
# OSS_BUCKET=my-etcd-backups
# OSS_REGION=cn-hangzhou
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# Storage Configuration - GCS (Google Cloud)
# STORAGE_PROVIDER=GCS
# GCS_BUCKET=my-etcd-backups
# GCS_REGION=us-central1

# =============================================================================
# Encryption Configuration
# =============================================================================
ENCRYPTION_ENABLED=false
ENCRYPTION_ALGORITHM=AES-256-GCM
# KMS_KEY_ID=arn:aws:kms:us-east-1:123456789:key/abc-def
# ENCRYPTION_SECRET_NAME=etcd-encryption-key

# =============================================================================
# Backup Configuration
# =============================================================================
BACKUP_MODE=Full
BACKUP_CONCURRENCY=3
BACKUP_CHUNK_SIZE=10485760
BACKUP_VALIDATION_ENABLED=true
BACKUP_CONSISTENCY_CHECK=true
BACKUP_HASH_ALGORITHM=sha256

# Retention Policy
RETENTION_MAX_BACKUPS=30
RETENTION_MAX_AGE=720h

# =============================================================================
# Restore Configuration
# =============================================================================
RESTORE_MODE=Full
RESTORE_QUIESCE_CLUSTER=true
RESTORE_PRE_CHECK_ENABLED=true
RESTORE_POST_CHECK_ENABLED=true

# =============================================================================
# Schedule Configuration
# =============================================================================
SCHEDULE_DEFAULT_CRON="0 2 * * *"
SCHEDULE_CONCURRENCY_POLICY=Forbid
SCHEDULE_SUCCESSFUL_JOBS_HISTORY_LIMIT=3
SCHEDULE_FAILED_JOBS_HISTORY_LIMIT=1

# =============================================================================
# Monitoring Configuration
# =============================================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_NAMESPACE=monitoring
PROMETHEUS_RETENTION=15d
PROMETHEUS_STORAGE_SIZE=10Gi

GRAFANA_ENABLED=true
GRAFANA_NAMESPACE=monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Alerting
ALERTING_ENABLED=true
ALERTMANAGER_URL=http://alertmanager:9093
SLACK_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=
EMAIL_FROM_ADDRESS=

# =============================================================================
# Security Configuration
# =============================================================================
RBAC_ENABLED=true
NETWORK_POLICY_ENABLED=true
POD_SECURITY_POLICY_ENABLED=false

# TLS Configuration
TLS_ENABLED=true
TLS_CERT_SECRET=etcd-guardian-tls
TLS_MIN_VERSION=TLSv1.2

# Authentication (Optional)
AUTH_ENABLED=false
AUTH_TYPE=OIDC
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# =============================================================================
# Resource Limits
# =============================================================================
OPERATOR_CPU_REQUEST=100m
OPERATOR_CPU_LIMIT=500m
OPERATOR_MEMORY_REQUEST=128Mi
OPERATOR_MEMORY_LIMIT=512Mi

BACKEND_CPU_REQUEST=100m
BACKEND_CPU_LIMIT=500m
BACKEND_MEMORY_REQUEST=128Mi
BACKEND_MEMORY_LIMIT=512Mi

WEBUI_CPU_REQUEST=50m
WEBUI_CPU_LIMIT=200m
WEBUI_MEMORY_REQUEST=64Mi
WEBUI_MEMORY_LIMIT=256Mi

# =============================================================================
# Kubernetes Configuration
# =============================================================================
KUBERNETES_SERVICE_HOST=kubernetes.default.svc
KUBERNETES_SERVICE_PORT=443
KUBECONFIG=

# Namespace Configuration
WATCH_NAMESPACE=
POD_NAMESPACE=etcd-guardian-system

# =============================================================================
# Development Configuration (Override for local development)
# =============================================================================
# DEVELOPMENT_MODE=true
# LOG_LEVEL=debug
# LOG_FORMAT=text
# GIN_MODE=debug
# RATE_LIMIT_ENABLED=false

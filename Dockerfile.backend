FROM golang:1.22-alpine AS builder

WORKDIR /workspace

RUN apk add --no-cache git make gcc musl-dev

COPY backend/go.mod backend/go.sum* ./
RUN go mod download || go mod tidy

COPY backend/ .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -a -installsuffix cgo -ldflags '-w -s -extldflags "-static"' -o bin/backend main.go

FROM gcr.io/distroless/static:nonroot

WORKDIR /

COPY --from=builder /workspace/bin/backend .

USER nonroot:nonroot

EXPOSE 8080

ENTRYPOINT ["/backend"]
